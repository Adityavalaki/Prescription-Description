{
  "expo": {
    "name": "Medira",
    "slug": "medira",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "medira",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f4c9457f-7516-4512-aa3d-04fcf71e20eb",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B3F46"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adityavalaki.medira"
    },
    "android": {
      "package": "com.adityavalaki.medira",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0B3F46"
      },
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Medira needs access to your photos so you can pick a prescription to scan.",
          "cameraPermission": "Medira needs your camera to photograph a prescription."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0E7C86",
          "sounds": [
            "./assets/sounds/chime.wav",
            "./assets/sounds/marimba.wav",
            "./assets/sounds/bells.wav",
            "./assets/sounds/sunrise.wav",
            "./assets/sounds/pulse.wav",
            "./assets/sounds/classic.wav"
          ]
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Medira adds a doctor-visit reminder to your calendar before your medicine runs out."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Medira uses your camera to photograph a prescription for scanning.",
          "recordAudioAndroid": false
        }
      ],
      "@react-native-google-signin/google-signin",
      "./plugins/withMediraAlarm",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "f4c9457f-7516-4512-aa3d-04fcf71e20eb"
      }
    }
  }
}
